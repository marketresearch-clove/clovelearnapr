# ================================================
# TTS Configuration - FREE + UNLIMITED Setup
# ================================================
# Text-to-Speech for LMS using self-hosted Piper TTS
# Primary provider: Piper (FREE, unlimited)
# Fallback provider: Browser Web Speech API
# 
# ✅ Zero external API costs
# ✅ Unlimited generation capacity
# ✅ Production scalable: $5-10/month VPS
# ================================================

# ========== PIPER TTS (PRIMARY - FREE) ==========
# Self-hosted Piper TTS server URL
# Development: http://localhost:5002
# Production: https://tts.yourdomain.com
# 
# To run Piper locally:
#   1. Install: pip install piper-tts
#   2. Start: piper-tts-server --host 0.0.0.0 --port 5002
#   3. Should be available at http://localhost:5002
VITE_PIPER_API_URL=http://localhost:5002

# ========== VOICE PREFERENCES ==========
# Default voice gender for synthesis
# Options: 'female' | 'male'
# 
# Female voices (recommended for teaching):
#   - lessac-high: Clear, natural teacher voice (best quality)
#   - amy-medium: Natural, slightly faster
#
# Male voices:
#   - ryan-high: Natural, authoritative
VITE_DEFAULT_VOICE_GENDER=female

# ========== CACHING & OPTIMIZATION ==========
# Enable audio caching for instant replay
# Caches synthesis results in Supabase database
# Recommended: true (significantly faster playback)
VITE_TTS_ENABLE_CACHE=true

# Cache retention period (days)
# Audio older than this is auto-deleted via cleanup function
# Recommended: 30 days (balances storage and freshness)
VITE_TTS_CACHE_RETENTION_DAYS=30

# Pre-generate audio during course creation
# Synthesis happens on course upload instead of first playback
# Recommended: true (better first-load experience)
VITE_TTS_PRE_GENERATE=true

# ========== QUALITY SETTINGS ==========
# Synthesis speed multiplier
# 0.85 = slower for clarity (best for 10-30 min lectures)
# 0.9 = natural teaching pace (recommended)
# 1.0 = normal speed
# 1.1 = slightly faster (summaries, notes)
VITE_TTS_DEFAULT_SPEED=0.9

# Audio quality tier
# high = lessac-high voice (best quality, slower synthesis)
# medium = amy-medium voice (balanced quality & speed)
# low = amy-medium voice (instant synthesis)
VITE_TTS_DEFAULT_QUALITY=high

# ========== BROWSER FALLBACK ==========
# Enable Browser Web Speech API as fallback
# Used when Piper is unavailable (network issues, server down)
# Cost: Free (built into browser)
# Always recommended: true
VITE_TTS_ENABLE_BROWSER_FALLBACK=true

# ========== LOGGING & DEBUG ==========
# Enable verbose TTS logging in browser console
# true = detailed [TTS:FREE], [TTS:PIPER], [TTS:BROWSER] logs
# false = minimal logging (production recommended)
VITE_TTS_DEBUG=false

# ================================================
# DEPLOYMENT INSTRUCTIONS
# ================================================
#
# LOCAL DEVELOPMENT:
#   1. Run Piper: piper-tts-server
#   2. VITE_PIPER_API_URL=http://localhost:5002
#   3. npm run dev
#   4. Instant development iteration
#
# PRODUCTION VPS:
#   1. Provision small VPS ($5-10/month)
#      Ubuntu 20.04+ recommended
#   2. Install Piper: pip install piper-tts
#   3. Start with systemd/supervisor:
#      piper-tts-server --host 0.0.0.0 --port 5002
#   4. Setup reverse proxy (Nginx):
#      - Forward /api/* to localhost:5002
#      - Configure CORS headers
#   5. Set VITE_PIPER_API_URL=https://tts.yourdomain.com
#   6. Audio cached in Supabase (free tier: 50GB)
#
# COST ANALYSIS:
#   Legacy approach (Coqui):
#      $1-5 per 1M characters → $50-500/month for active course
#   Enterprise cloud TTS (Google):
#      $16 per 1M characters → $1600/month for active course
#   Self-hosted Piper (Skill-Spire):
#      $5-10/month VPS = UNLIMITED TTS synthesis
#      Additional: Supabase storage ($0-100/month)
#   SAVINGS: 50-320x cheaper than alternatives
#
# ================================================
